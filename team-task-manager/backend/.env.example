# Copy this file to .env for local development (never commit .env).
# On Railway, set these in the service Variables panel.

# PostgreSQL connection string.
# Railway provides this automatically when you add a Postgres plugin.
# Local example: postgres://postgres:password@localhost:5432/taskmanager
DATABASE_URL=

# Secret used to sign JWT tokens. Use a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Allowed CORS origins for the frontend (comma-separated).
# In production set this to your Vercel URL, e.g.:
# CORS_ORIGIN=https://your-app.vercel.app
CORS_ORIGIN=*

# Port the server listens on.
# Railway injects PORT automatically — this is the local fallback only.
PORT=8080
